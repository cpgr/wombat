[Tests]
  design = 'VEPlumeFootprintPostprocessor.md VEMobileCO2MassPostprocessor.md '
           'VETrappedCO2MassPostprocessor.md VEDissolvedCO2MassPostprocessor.md'
  issues = '#1'

  [ve_postprocessors]
    type = CSVDiff
    input = 've_postprocessors.i'
    csvdiff = 've_postprocessors_csv.csv'
    rel_err = 1.0e-5
    abs_zero = 1.0e-10
    requirement = 'The VE diagnostic postprocessors shall correctly compute '
                  'plume footprint (1000 m), mobile CO2 mass (1 680 000 kg), '
                  'trapped CO2 mass (0 kg), dissolved CO2 mass (0 kg), and '
                  'maximum pp_top (1e7 Pa via NodalMaxValue) for a uniform-field '
                  'one-step verification case with known analytical values.'
  []

  [ve_postprocessors_spatial]
    type = CSVDiff
    input = 've_postprocessors_spatial.i'
    csvdiff = 've_postprocessors_spatial_csv.csv'
    rel_err = 1.0e-5
    abs_zero = 1.0e-10
    requirement = 'The VE diagnostic postprocessors shall correctly integrate '
                  'spatially varying inputs: sat_n = max(0, 0.6 - 0.001*x) '
                  '(plume present only in [0, 600 m]), sat_n_trap = 0.10, '
                  'X_co2 = 0.05.  Expected: footprint = 600 m, '
                  'mass_mobile = 350 000 kg, mass_trapped = 280 000 kg, '
                  'mass_dissolved = 164 000 kg.'
  []
[]
