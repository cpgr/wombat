[Tests]
  design = 'VESaturationMaxAux.md VERelativePermeability.md VERelPermHysteresisUO.md '
           'VETrappedSaturationAux.md'
  issues = '#1'

  [sat_n_max_tracking]
    type = CSVDiff
    input = 'sat_n_max_tracking.i'
    csvdiff = 'sat_n_max_tracking_csv.csv'
    requirement = 'VESaturationMaxAux shall track the running maximum of sat_n: '
                  'sat_n_max shall rise with sat_n during drainage and stay pinned at '
                  'the historical peak as sat_n recedes during imbibition, providing '
                  'the turning point for the hysteretic relative permeability.'
  []

  [column_cycle]
    type = CSVDiff
    input = 'column_cycle.i'
    csvdiff = 'column_cycle_csv.csv'
    requirement = 'VERelPermHysteresisUO and VETrappedSaturationAux shall reproduce the '
                  'closed-form Land residual-trapping saturation over a drainage -> '
                  'imbibition cycle: sat_n_trap shall be zero on drainage, zero at the '
                  'turning point, and grow to the Land residual s_gr (mobile CO2 -> 0) '
                  'as sat_n recedes to s_gr.'
  []

  [hysteresis_jacobian]
    type = PetscJacobianTester
    input = 'hysteresis_jacobian.i'
    ratio_tol = 1.0e-7
    difference_tol = 1.0e-4
    cli_args = '-mat_fd_type ds'
    requirement = 'The hysteretic relperm path (VERelPermHysteresisUO -> VERelPerm -> '
                  'VEAdvectiveFluxS) shall produce a Jacobian consistent with the PETSc '
                  'finite-difference approximation to within ratio tolerance 1e-7 on the '
                  'imbibition branch, confirming the scanning-curve dRelativePermeability '
                  'seeded by the three-argument relativePermeabilityAD.'
  []

  [hysteresis_drainage_fv]
    type = CSVDiff
    input = 'hysteresis_drainage_fv.i'
    csvdiff = 'hysteresis_drainage_fv_csv.csv'
    rel_err = 1.0e-5
    requirement = 'VERelPermHysteresisUO driven through the FV functor adapter '
                  '(VEFVRelPerm with the sat_n_max functor) and VEFVAdvectiveFlux shall '
                  'reduce exactly to the sharp Buckley-Leverett result under monotonic '
                  'drainage: co2_volume shall equal the analytical front 5e-4*t to within '
                  'a relative error of 1e-5, confirming the hysteretic relperm does not '
                  'perturb drainage and that the FV sat_n_max wiring is correct.'
  []
[]
