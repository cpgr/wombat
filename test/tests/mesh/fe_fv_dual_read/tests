[Tests]
  design = 'VEGeometry.md'
  issues = '#1'

  [read_both]
    type = CSVDiff
    input = 'read_both.i'
    csvdiff = 'read_both_csv.csv'
    # Reads the committed fixture dual_field.e, which carries z_top/z_bottom in BOTH
    # the nodal and elemental Exodus namespaces under the same names (standing in for
    # an `ex2ve --z-discretization both` upscaling mesh). The fixture is committed
    # rather than regenerated by a prereq step because MOOSE cannot write same-name
    # dual-namespace fields itself; regenerate it with make_dual_field_mesh.py
    # (requires the netCDF4 Python package) if the geometry/values ever change.
    rel_err = 1.0e-8
    requirement = 'When a field name exists in both the nodal and elemental Exodus '
                  'namespaces, MOOSE shall resolve which to read from the receiving '
                  'variable type so one mesh drives the FE and FV solvers: a LAGRANGE '
                  'variable shall read the nodal z_top/z_bottom (mins -900 / -1000) and a '
                  'MooseVariableFVReal the elemental ones (mins -896 / -996), and VEGeometry '
                  'consuming the nodal fields shall recover the exact horizontal slope '
                  '(grad_z_top = 0.5, 0.3) on the flattened mesh.'
  []
