[Tests]
  design = 'VEFlowFE.md VEFlowFV.md'
  issues = '#2'

  [ve_flow_fe]
    type = CSVDiff
    input = 've_flow_fe.i'
    csvdiff = 've_flow_fe_csv.csv'
    cli_args = 'Executioner/end_time=5e4'
    rel_err = 1.0e-4
    abs_zero = 1.0e-6
    requirement = 'The [Physics/VEFlow/FiniteElement] action shall create the primary '
                  'variables, the FE flow kernels and the FE material chain so that a '
                  'sloped-aquifer solve reproduces the hand-assembled nc_sloped.i result '
                  '(co2_integral, gravity_nose) to within rel_err = 1e-4.'
  []

  [ve_flow_fv]
    type = CSVDiff
    input = 've_flow_fv.i'
    csvdiff = 've_flow_fv_csv.csv'
    cli_args = 'Executioner/end_time=5e4'
    rel_err = 1.0e-4
    abs_zero = 1.0e-6
    requirement = 'The [Physics/VEFlow/FiniteVolume] action shall create the FV primary '
                  'variables, the FV flow kernels, the elemental material chain and the '
                  'functor materials so that a sloped-aquifer solve reproduces the '
                  'hand-assembled nc_sloped_fv.i result to within rel_err = 1e-4.'
  []

  [ve_flow_fe_capillary]
    type = PetscJacobianTester
    input = 've_flow_fe_capillary.i'
    ratio_tol = 1.0e-7
    difference_tol = 1.0e-4
    cli_args = 'Executioner/end_time=1000 Executioner/dt=500 -mat_fd_type ds '
               'ICs/sat_n_ic/value=0.5 BCs/sat_n_left/value=0.5'
    requirement = 'The [Physics/VEFlow/FiniteElement] action with capillary = sharp_interface shall '
                  'create VEPlumeReconstruction and VEUpscaledCapPressure and set capillary '
                  'on VEAdvectiveFluxS, producing a Jacobian consistent with the PETSc '
                  'finite-difference approximation to within ratio tolerance 1e-7.'
  []

  [ve_flow_fv_capillary]
    type = PetscJacobianTester
    input = 've_flow_fv_capillary.i'
    ratio_tol = 1.0e-7
    difference_tol = 1.0e-4
    cli_args = 'Executioner/end_time=1000 Executioner/dt=500 -mat_fd_type ds '
               'ICs/sat_n_ic/value=0.5 FVBCs/sat_n_left/value=0.5'
    requirement = 'The [Physics/VEFlow/FiniteVolume] action with capillary = sharp_interface shall '
                  'create the VEFVCapPressure functor material (deriving delta_rho from the '
                  'density functors) and set capillary on VEFVAdvectiveFlux, producing a '
                  'Jacobian consistent with the PETSc finite-difference approximation to '
                  'within ratio tolerance 1e-7.'
  []

  [ve_flow_fe_capillary_fringe]
    type = PetscJacobianTester
    input = 've_flow_fe_capillary_fringe.i'
    ratio_tol = 1.0e-7
    difference_tol = 1.0e-4
    cli_args = '-mat_fd_type ds'
    requirement = 'The [Physics/VEFlow/FiniteElement] action with capillary = capillary_fringe '
                  'shall run VEPlumeReconstruction and VEUpscaledCapPressure in Newton-inversion '
                  'mode against the shared pc_uo Sw(Pc) table, producing the fringe S_n(h) flux '
                  'coefficients with a Jacobian consistent with the PETSc finite-difference '
                  'approximation to within ratio tolerance 1e-7 at a non-uniform interior state '
                  '(both the grad(sat_n) and grad(H) fringe terms active).'
  []

  [ve_flow_fv_capillary_fringe]
    type = PetscJacobianTester
    input = 've_flow_fv_capillary_fringe.i'
    ratio_tol = 1.0e-7
    difference_tol = 1.0e-3
    cli_args = '-mat_fd_type ds'
    requirement = 'The [Physics/VEFlow/FiniteVolume] action with capillary = capillary_fringe '
                  'shall build VEFVCapPressure in Newton-inversion mode against the shared pc_uo '
                  'Sw(Pc) table, producing the fringe S_n(h) flux coefficients with a Jacobian '
                  'consistent with the PETSc finite-difference approximation to within ratio '
                  'tolerance 1e-7.'
  []

  [ve_flow_fv_capillary_fringe_gradh]
    type = PetscJacobianTester
    input = 've_flow_fv_capillary_fringe_gradh.i'
    ratio_tol = 1.0e-7
    difference_tol = 1.0e-3
    cli_args = '-mat_fd_type ds'
    requirement = 'The [Physics/VEFlow/FiniteVolume] action with capillary = capillary_fringe on '
                  'a laterally varying thickness shall additionally exercise the grad(H) fringe '
                  'term ve_dPcup_dH = delta_rho*g*sat_n/S_n(h), using advected_interp_method = '
                  'average so the no-flow (zero-velocity) state is differentiable, with a Jacobian '
                  'consistent with the PETSc finite-difference approximation to within ratio '
                  'tolerance 1e-7.'
  []

  # --- Option equivalence (generated objects reproduce the hand-written cases) ---

  [ve_flow_dissolution_fe]
    type = CSVDiff
    input = 've_flow_dissolution_fe.i'
    csvdiff = 've_flow_dissolution_fe_csv.csv'
    rel_err = 1.0e-8
    requirement = 'The [Physics/VEFlow/FiniteElement] action with enable_dissolution = true '
                  'shall add VEDissolutionSink on the CO2 equation (the VEDissolution material '
                  'remaining user-supplied), reproducing the constant-rate dissolution result '
                  'of dissolution/constant_rate.i.'
  []

  [ve_flow_dissolution_fv]
    type = CSVDiff
    input = 've_flow_dissolution_fv.i'
    csvdiff = 've_flow_dissolution_fv_csv.csv'
    rel_err = 1.0e-8
    requirement = 'The [Physics/VEFlow/FiniteVolume] action with enable_dissolution = true '
                  'shall add VEFVDissolutionSink, reproducing the constant-rate dissolution '
                  'result of dissolution/constant_rate_fv.i.'
  []

  [ve_flow_anisotropic]
    type = CSVDiff
    input = 've_flow_anisotropic.i'
    csvdiff = 've_flow_anisotropic_csv.csv'
    rel_err = 1.0e-8
    requirement = 'The [Physics/VEFlow/FiniteElement] action shall forward the off-diagonal '
                  'K_up_xy into VEPermeability so the manufactured anisotropic solution '
                  'pp(0.5,0.5) = 9 of permeability/anisotropic_permeability.i is recovered.'
  []

  [ve_flow_relperm_table]
    type = CSVDiff
    input = 've_flow_relperm_table.i'
    csvdiff = 've_flow_relperm_table_csv.csv'
    cli_args = 'Executioner/end_time=5000'
    rel_err = 1.0e-5
    requirement = 'The [Physics/VEFlow/FiniteElement] action shall wire a tabulated '
                  'VERelPermTableUO (relperm_uo) into the generated VERelPerm material so that a '
                  'table sampling the analytical sharp-interface curve (kr_n = sat_n, kr_w = 1 - '
                  'sat_n) reproduces the hand-assembled buckley_leverett/bl_flat_table.i '
                  'Buckley-Leverett result, confirming the field-case tabulated relperm plugs '
                  'into the Physics path with no other change.'
  []

  [ve_flow_exodus_fields]
    type = CSVDiff
    input = 've_flow_exodus_fields.i'
    csvdiff = 've_flow_exodus_fields_csv.csv'
    rel_err = 1.0e-8
    requirement = 'The [Physics/VEFlow/FiniteVolume] action shall accept AuxVariable names for '
                  'phi_bar, K_up_xx/yy/xy and z_top/z_bottom (the coupled-var path, mirroring a '
                  'real field workflow where petrophysical fields are read from an Exodus mesh), '
                  'threading them correctly through assignCoupled into the generated VEPorosity, '
                  'VEPermeability and VEGeometry materials: field values at the sample element '
                  '(50,50) shall reproduce the exodus/exodus_fields.i gold '
                  '(ve_H = 102.5, ve_phi_bar = 0.21, ve_K_up diagonal 1.05e-12/5e-13, '
                  'off-diagonal 2.5e-14).'
  []

  [ve_flow_var_names]
    type = CSVDiff
    input = 've_flow_var_names.i'
    csvdiff = 've_flow_var_names_csv.csv'
    cli_args = 'Executioner/end_time=5000'
    rel_err = 1.0e-5
    requirement = 'The [Physics/VEFlow/FiniteElement] action shall honour the pressure_variable '
                  'and saturation_variable rename parameters: renaming pp_top -> p_top and '
                  'sat_n -> s_co2 shall propagate through every generated kernel, material '
                  'coupling and aux-variable reference so that the renamed-variable solve '
                  'reproduces the buckley_leverett/bl_flat.i Buckley-Leverett result, confirming '
                  'the rename is transparent to the physics.'
  []

  # --- Negative tests (the Physics validation guards) ---

  [ve_flow_fv_user_geometry]
    type = CSVDiff
    input = 've_flow_fv_user_geometry.i'
    csvdiff = 've_flow_fv_user_geometry_csv.csv'
    cli_args = 'Executioner/end_time=5e4'
    rel_err = 1.0e-4
    abs_zero = 1.0e-6
    requirement = 'With define_geometry_variables = false the [Physics/VEFlow/FiniteVolume] '
                  'action shall defer to user-declared MooseVariableFVReal z_top/z_bottom and '
                  'reproduce the nc_sloped_fv result, confirming the explicit opt-out path.'
  []

  [err_fv_geometry_fe_variable]
    type = RunException
    input = 've_flow_fv_bad_geometry.i'
    expect_err = "is not a finite-volume variable"
    requirement = 'With define_geometry_variables = false, VEFlowFV shall error if a '
                  'user-provided geometry variable (z_top) is not a MooseVariableFVReal, since '
                  'a regular FE aux reads as zero on FV faces and silently kills the advective '
                  'flux.'
  []

  [err_dissolution_requires_flux]
    type = RunException
    input = 've_flow_fe.i'
    cli_args = 'Physics/VEFlow/FiniteElement/ve/enable_dissolution=true'
    expect_err = "dissolution_flux is required when enable_dissolution = true"
    requirement = 'The VE flow Physics shall error if enable_dissolution = true is selected '
                  'without dissolution_flux.'
  []

  [err_interface_requires_swr]
    type = RunException
    input = 've_flow_fe.i'
    cli_args = 'Physics/VEFlow/FiniteElement/ve/eos_reference_depth=interface'
    expect_err = "S_wr is required when eos_reference_depth = interface"
    requirement = 'The VE flow Physics shall error if eos_reference_depth = interface is '
                  'selected without S_wr.'
  []

  [err_geometry_double_declared]
    type = RunException
    input = 've_flow_fv.i'
    cli_args = 'AuxVariables/z_top/type=MooseVariableFVReal'
    expect_err = "z_top' has already been declared.*define_geometry_variables = true"
    requirement = 'With define_geometry_variables = true (the action owns the geometry '
                  'variables), the VE flow Physics shall error if the user also declares '
                  'z_top/z_bottom in [AuxVariables], rather than silently merging or emitting an '
                  'opaque type-mismatch error.'
  []

  [err_capillary_fringe_requires_pc_uo]
    type = RunException
    input = 've_flow_fe.i'
    cli_args = 'Physics/VEFlow/FiniteElement/ve/capillary=capillary_fringe'
    expect_err = "pc_uo is required when capillary = capillary_fringe"
    requirement = 'The VE flow Physics shall error if capillary = capillary_fringe is selected '
                  'without pc_uo, since the fringe reconstruction and upscaled-Pc coefficients '
                  'both need the column Sw(Pc) curve.'
  []

  [err_missing_field]
    type = RunException
    input = 've_flow_fe.i'
    cli_args = 'Physics/VEFlow/FiniteElement/ve/phi_bar=ghost_field'
    expect_err = "not present in the problem.*ghost_field"
    requirement = 'The VE flow Physics shall error with an actionable message if a coupled '
                  'field (here phi_bar) names a variable that is not present -- e.g. an Exodus '
                  'field the upscaling workflow did not emit -- rather than failing silently or '
                  'with an opaque downstream error.'
  []
[]
